rules_version = '2';

// Course Connect baseline Firestore rules (Unit 1 of multi-department support).
//
// Intent: replicate today's de-facto access posture with server-side enforcement.
// Before this file, every production write was guarded by client-side role
// checks only. This baseline establishes a minimum server-side floor so the
// Unit 7 department-scoping rules have something to layer on top.
//
// What this baseline enforces:
//   - Authenticated access for all reads.
//   - Self-write on users/{uid} (admins may also write other user docs to
//     support the existing admin grids).
//   - The `superAdmin` boolean field is NEVER client-writable under any
//     condition. Bootstrapping is exclusively via a one-time admin SDK script.
//   - Admin-only writes on course catalogs, assignments, and faculty-stats.
//   - Staff (admin or faculty) create/update on announcements.
//   - Self-write on the user's announcementStates subcollection.
//   - Owner-or-staff writes on research listings.
//
// Scope intentionally deferred to Unit 7:
//   - Scoping admin/faculty authority by department.
//   - Enforcing announcement audience filters at the rules layer.

service cloud.firestore {
  match /databases/{database}/documents {

    // --------- helpers ---------

    function isAuthed() {
      return request.auth != null;
    }
    function isSelf(uid) {
      return isAuthed() && request.auth.uid == uid;
    }
    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }
    function userRole() {
      return userDoc().data.role;
    }
    function isAdmin() {
      return isAuthed() && userRole() == 'admin';
    }
    function isFaculty() {
      return isAuthed() && userRole() == 'faculty';
    }
    function isStaff() {
      return isAdmin() || isFaculty();
    }
    // `superAdmin` must not be client-writable even by admins. This closes the
    // privilege-escalation window in the Unit 1..7 period where admin grids
    // may write other user docs. Allowed if the incoming doc either lacks the
    // field entirely or leaves it equal to the existing value.
    function notTouchingSuperAdmin() {
      return !('superAdmin' in request.resource.data)
          || (resource != null
              && request.resource.data.superAdmin == resource.data.superAdmin);
    }

    // --------- users ---------
    match /users/{uid} {
      allow read: if isAuthed();
      allow create: if (isSelf(uid) || isAdmin())
                    && !('superAdmin' in request.resource.data);
      allow update: if (isSelf(uid) || isAdmin())
                    && notTouchingSuperAdmin();
      allow delete: if isAdmin();

      // A user's own announcement read/ack state.
      match /announcementStates/{announcementId} {
        allow read, write: if isSelf(uid);
      }
    }

    // --------- semesters + courses ---------
    match /semesters/{semesterId} {
      allow read: if isAuthed();
      allow write: if isAdmin();

      match /courses/{courseId} {
        allow read: if isAuthed();
        allow write: if isAdmin();
      }
    }

    // Legacy flat `courses` collection (likely dead; confirmed/removed in Unit 6).
    match /courses/{courseId} {
      allow read: if isAuthed();
      allow write: if isAdmin();
    }

    // --------- applications ---------
    // Path: applications/{type}/uid/{uid} where `type` is a fixed set
    // (course_assistant, supervised_teaching) and `courses` is a map field
    // on the uid doc (not a subcollection). Applicant creates their own doc;
    // staff can read/update any.
    match /applications/{type}/uid/{uid} {
      allow read: if isSelf(uid) || isStaff();
      allow create: if isSelf(uid);
      allow update: if isSelf(uid) || isStaff();
      allow delete: if isSelf(uid) || isAdmin();
    }

    // --------- announcements ---------
    // Baseline: audience filtering stays in the client query. Unit 7 enforces
    // audience at the rule layer using the users.roles array.
    match /announcements/{announcementId} {
      allow read: if isAuthed();
      allow create, update: if isStaff();
      allow delete: if isAdmin();
    }

    // --------- research listings ---------
    match /research-listings/{listingId} {
      allow read: if isAuthed();
      allow create: if isAuthed();
      allow update: if isStaff()
                    || (resource.data.keys().hasAny(['createdBy', 'uid'])
                        && (resource.data.get('createdBy', '') == request.auth.uid
                            || resource.data.get('uid', '') == request.auth.uid));
      allow delete: if isAdmin()
                    || (resource.data.keys().hasAny(['createdBy', 'uid'])
                        && (resource.data.get('createdBy', '') == request.auth.uid
                            || resource.data.get('uid', '') == request.auth.uid));

      // Student applications to a research listing.
      match /applications/{appId} {
        allow read: if isAuthed();
        allow create: if isAuthed();
        allow update: if isAuthed();
        allow delete: if isAuthed();
      }
    }

    // --------- faculty-stats (collection is named 'faculty') ---------
    match /faculty/{facultyId} {
      allow read: if isAuthed();
      allow write: if isAdmin();
    }

    // --------- assignments ---------
    match /assignments/{uid} {
      allow read: if isSelf(uid) || isStaff();
      allow create, update: if isAdmin();
      allow delete: if isSelf(uid) || isAdmin();
    }

    // --------- departments (Unit 2+) ---------
    // Any authed user may read the departments list (used by pickers, research
    // filters, announcement audience UI). Writes are restricted to super
    // admins via Cloud Function (admin SDK bypasses rules); we still deny
    // client writes here as defense-in-depth.
    match /departments/{deptId} {
      allow read: if isAuthed();
      allow write: if false;
    }

    // --------- pending memberships (Unit 4) ---------
    // The invitee needs to read their own pending doc to see that an invite
    // exists; admins/super admins need read+delete to manage the list.
    // Writes go through Cloud Functions (admin SDK) only.
    match /pendingMemberships/{email} {
      allow read: if isAuthed()
                  && (request.auth.token.email != null
                      && request.auth.token.email.lower() == email);
      allow read: if isAdmin();
      allow write: if false;
    }

    // --------- course-fetch pipeline ---------
    // Configs and per-run history live under `courseFetchConfigs`. All writes
    // (including scheduled runs) go through Cloud Functions using the admin
    // SDK, which bypasses rules. Client reads are admin-only; direct client
    // writes are denied as defense-in-depth.
    match /courseFetchConfigs/{configId} {
      allow read: if isAdmin();
      allow write: if false;

      match /runs/{runId} {
        allow read: if isAdmin();
        allow write: if false;
      }
    }

    // Normalized scraped catalog. Any authed user may read so it can drive
    // pickers and future student/faculty features; writes go through Cloud
    // Functions only.
    match /catalog/{courseId} {
      allow read: if isAuthed();
      allow write: if false;

      match /sections/{sectionId} {
        allow read: if isAuthed();
        allow write: if false;
      }
    }

    // --------- login events (audit trail; writes only) ---------
    // auth_context.js appends a row on first sign-in per session. No one
    // reads these from the client today.
    match /login_events/{eventId} {
      allow read: if false;
      allow create: if isAuthed();
      allow update, delete: if false;
    }
  }
}
